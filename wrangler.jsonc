{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "muddy-sunset-8bed",
  "compatibility_date": "2026-07-06",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": [
      "node_modules",
      ".wrangler",
      ".git",
      ".github",
      ".gitignore",
      "wrangler.jsonc",
      "package.json",
      "package-lock.json",
      ".npmrc"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
